---
import ResourceCard from "../cards/ResourceCard.astro";

const MAYA_API_URL = import.meta.env.MAYA_API_URL || "http://maya.local";

const fallbackResources = [
	{
		title: "Como optimizar rutas de entrega en Panamá",
		description: "Guía para reducir kilometraje improductivo y mejorar puntualidad en zonas urbanas.",
		href: "/blog/como-optimizar-rutas-de-entrega-en-Panamá"
	},
	{
		title: "Qué es ePOD y por qué reduce reclamaciones",
		description: "Buenas prácticas de prueba de entrega digital en operaciones con alto volumen.",
		href: "/blog/que-es-la-prueba-de-entrega-electronica-epod"
	},
	{
		title: "KPIs logísticos para medir última milla",
		description: "Indicadores esenciales para dirigir decisiones en operaciones de entrega.",
		href: "/blog/kpis-logísticos-para-medicion-de-ultima-milla"
	}
];

let resources = fallbackResources;

try {
	const res = await fetch(`${MAYA_API_URL}/api/blog/posts?per_page=3`);
	if (res.ok) {
		const json = await res.json();
		const posts = json.data ?? [];
		if (posts.length > 0) {
			resources = posts.map((post: any) => ({
				title: post.title,
				description: post.excerpt ?? "",
				href: `/blog/${post.slug}`
			}));
		}
	}
} catch {
	// Fall back to hardcoded resources on API failure
}
---

<section class="section" aria-labelledby="blog-seo-title">
	<div class="shell">
		<h2 id="blog-seo-title" class="reveal">Centro de recursos SEO para crecimiento orgánico</h2>
		<p class="section-copy reveal">
			Bloque preparado para conectar la landing con contenido de búsqueda informacional y fortalecer autoridad sectorial.
		</p>
		<div class="cards cards-3">
			{resources.map((resource) => <ResourceCard {...resource} />)}
		</div>
	</div>
</section>
