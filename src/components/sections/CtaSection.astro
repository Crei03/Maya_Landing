<section id="formulario" class="py-24">
	<div class="max-w-7xl mx-auto px-8">
		<div class="relative rounded-[3rem] bg-on-surface text-surface overflow-hidden p-8 md:p-20">
			<div class="relative z-10 grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
				<div>
				<h2 class="font-headline text-4xl md:text-6xl font-extrabold leading-tight mb-6">Solicita una demostración de Maya para tu operación logística</h2>
				<p class="text-surface-variant text-xl mb-8">Activa en días una operación de última milla con analítica en tiempo real, rutas optimizadas y experiencia superior para tus clientes en Panamá.</p>
					<div class="space-y-4">
						<div class="flex items-center gap-3 text-surface">
							<span class="material-symbols-outlined text-primary">rocket_launch</span>
							<p>Demo personalizada para tu tipo de operación y volumen de entregas.</p>
						</div>
						<div class="flex items-center gap-3 text-surface">
							<span class="material-symbols-outlined text-primary">group</span>
							<p>Acompañamiento comercial y operativo para acelerar adopción del equipo.</p>
						</div>
						<div class="flex items-center gap-3 text-surface">
							<span class="material-symbols-outlined text-primary">schedule</span>
							<p>Plan de implementación por etapas para ver mejoras desde el primer mes.</p>
						</div>
					</div>
				</div>
				<div class="bg-surface p-10 rounded-[2rem] text-on-surface shadow-2xl">
					<form class="space-y-4" method="post" action="https://formsubmit.co/creidev03@gmail.com">
						<input name="_captcha" type="hidden" value="false" />
						<input name="_subject" type="hidden" value="Nueva solicitud de demostración de Maya" />
						<input name="_template" type="hidden" value="table" />
						<input aria-hidden="true" class="hidden" tabindex="-1" type="text" name="_honey" autocomplete="off" />
						<div>
							<label class="block text-sm font-bold mb-2" for="contact-name">Nombre completo del contacto</label>
							<input id="contact-name" name="contact_name" class="w-full bg-surface-container-highest border-none rounded-xl p-4 focus:ring-2 focus:ring-primary/20" placeholder="Ej. Javier De Obaldia" type="text" required minlength="2" maxlength="80" autocomplete="name" pattern="[A-Za-zÀ-ÿ0-9ÁÉÍÓÚÜÑáéíóúüñ'’.,&()\-\s]{2,80}" data-sanitize="text"/>
						</div>
						<div>
							<label class="block text-sm font-bold mb-2" for="contact-email">Correo corporativo</label>
							<input id="contact-email" name="contact_email" class="w-full bg-surface-container-highest border-none rounded-xl p-4 focus:ring-2 focus:ring-primary/20" placeholder="javier@empresa.com" type="email" required maxlength="120" autocomplete="email" inputmode="email" data-sanitize="email"/>
						</div>
						<div>
							<label class="block text-sm font-bold mb-2" for="company-name">Empresa de logística</label>
							<input id="company-name" name="company_name" class="w-full bg-surface-container-highest border-none rounded-xl p-4 focus:ring-2 focus:ring-primary/20" placeholder="Tu Logística SA" type="text" required minlength="2" maxlength="100" autocomplete="organization" pattern="[A-Za-zÀ-ÿ0-9ÁÉÍÓÚÜÑáéíóúüñ'’.,&()\-\s]{2,100}" data-sanitize="text"/>
						</div>
						<div>
							<label class="block text-sm font-bold mb-2" for="phone-number">Número de teléfono</label>
							<input id="phone-number" name="phone_number" class="w-full bg-surface-container-highest border-none rounded-xl p-4 focus:ring-2 focus:ring-primary/20" placeholder="6123 4567" type="text" required minlength="7" maxlength="20" autocomplete="tel" inputmode="tel" pattern="[0-9+()\s-]{7,20}" data-sanitize="phone"/>
						</div>
						<button class="w-full primary-gradient-btn text-white py-4 rounded-xl font-bold text-lg shadow-lg active:scale-95 transition-transform mt-4" type="submit">
							Empezar ahora
						</button>
						<p class="text-center text-xs text-on-surface-variant mt-4">Al enviar, aceptas nuestras políticas de privacidad y términos de servicio.</p>
					</form>
				</div>
			</div>
		</div>
	</div>
</section>

<script type="module">
	const formElement = document.querySelector('#formulario form');
	const phoneField = document.querySelector('#phone-number');

	if (phoneField instanceof HTMLInputElement && formElement instanceof HTMLFormElement) {
		const allowedPhoneCharacters = /^[0-9+()\s-]$/;
		const validPhonePattern = /^[0-9+()\s-]{7,20}$/;
		const containsLettersPattern = /[A-Za-zÀ-ÿ]/;

		const sanitizePhone = (value) => value.replace(/[^0-9+()\s-]/g, '');

		const validatePhoneBeforeSubmit = () => {
			const phoneValue = phoneField.value.trim();
			const hasLetters = containsLettersPattern.test(phoneValue);
			const hasInvalidFormat = !validPhonePattern.test(phoneValue);

			if (hasLetters || hasInvalidFormat) {
				phoneField.setCustomValidity('Ingresa un teléfono válido usando solo números y símbolos permitidos (+, -, espacios o paréntesis).');
				return false;
			}

			phoneField.setCustomValidity('');
			return true;
		};

		phoneField.addEventListener('beforeinput', (event) => {
			if (typeof event.data === 'string' && event.data.length > 0) {
				for (const character of event.data) {
					if (!allowedPhoneCharacters.test(character)) {
						event.preventDefault();
						return;
					}
				}
			}
		});

		phoneField.addEventListener('keydown', (event) => {
			if (event.ctrlKey || event.metaKey || event.altKey) {
				return;
			}

			const navigationKeys = ['Backspace', 'Delete', 'ArrowLeft', 'ArrowRight', 'Tab', 'Home', 'End', 'Enter'];

			if (navigationKeys.includes(event.key)) {
				return;
			}

			if (!allowedPhoneCharacters.test(event.key)) {
				event.preventDefault();
			}
		});

		phoneField.addEventListener('paste', (event) => {
			event.preventDefault();
			const pastedText = event.clipboardData?.getData('text') ?? '';
			phoneField.value = sanitizePhone(`${phoneField.value}${pastedText}`);
			phoneField.dispatchEvent(new Event('input', { bubbles: true }));
		});

		phoneField.addEventListener('drop', (event) => {
			event.preventDefault();
		});

		phoneField.addEventListener('input', () => {
			const sanitizedValue = sanitizePhone(phoneField.value);

			if (phoneField.value !== sanitizedValue) {
				phoneField.value = sanitizedValue;
			}

			if (phoneField.validity.customError) {
				validatePhoneBeforeSubmit();
			}
		});

		formElement.addEventListener('submit', (event) => {
			if (!validatePhoneBeforeSubmit()) {
				event.preventDefault();
				phoneField.reportValidity();
			}
		});
	}
</script>
