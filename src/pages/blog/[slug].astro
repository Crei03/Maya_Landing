---
import MainLayout from "../../layouts/MainLayout.astro";
import RelatedPosts from "../../components/Blog/RelatedPosts.astro";
import PostCta from "../../components/Blog/PostCta.astro";
import { marked } from "marked";

export async function getStaticPaths() {
	const MAYA_API_URL = import.meta.env.MAYA_API_URL;
	try {
		const res = await fetch(`${MAYA_API_URL}/api/blog/posts?per_page=100`);
		if (res.ok) {
			const json = await res.json();
			const posts = json.data ?? [];
			return posts.map((post) => ({
				params: { slug: post.slug },
				props: { post, related: post.related ?? [] },
			}));
		}
	} catch {
		// Return empty array if API unreachable
	}
	return [];
}

const MAYA_API_URL = import.meta.env.MAYA_API_URL;

const { post, related } = Astro.props;

if (!post) {
	return Astro.redirect("/blog");
}

const date = new Date(post.published_at);
const formattedDate = date.toLocaleDateString("es-PA", {
	day: "2-digit",
	month: "long",
	year: "numeric",
});

const renderedContent = marked.parse(post.content ?? "");

const seoTitle = post.meta_title || post.title;
const seoDescription = post.meta_description || post.excerpt || "";

// Images for gallery: featured + uploaded
const galleryImages = [];
if (post.featured_image_url) galleryImages.push({ url: post.featured_image_url, alt: post.title, isFeatured: true });
if (post.images?.length) {
	post.images.forEach((img) => {
		galleryImages.push({ url: img.url || img.path, alt: img.alt_text || post.title, isFeatured: false });
	});
}
---

<MainLayout title={`${seoTitle} | Maya Blog`} description={seoDescription}>
	<!-- Article -->
	<article class="relative pt-28 md:pt-36">
		<!-- Hero gradient -->
		<div class="absolute inset-x-0 top-0 h-[50vh] bg-gradient-to-b from-surface-bright via-surface to-transparent" />

		<div class="relative mx-auto max-w-4xl px-8">
			<!-- Back link -->
			<a href="/blog" class="mb-8 inline-flex items-center gap-1.5 text-sm font-medium text-on-surface-variant transition-colors hover:text-primary dark:text-gray-300 dark:hover:text-primary">
				<span class="material-symbols-outlined text-lg">arrow_back</span>
				Volver al blog
			</a>

			<!-- Meta row -->
			<div class="mb-4 flex flex-wrap items-center gap-3 text-xs font-semibold uppercase tracking-[0.12em]">
				<time class="text-primary dark:text-secondary">{formattedDate}</time>
				{post.reading_time && (
					<span class="inline-flex items-center gap-1 text-on-surface-variant dark:text-gray-400">
						<span class="material-symbols-outlined text-sm">schedule</span>
						{post.reading_time} min de lectura
					</span>
				)}
			</div>

			<!-- Title -->
			<h1 class="font-headline text-4xl font-extrabold leading-[1.15] tracking-tight text-on-surface md:text-5xl lg:text-6xl">
				{post.title}
			</h1>

			<!-- Author -->
			{post.author && (
				<div class="mt-6 flex items-center gap-3">
					<div class="flex h-11 w-11 items-center justify-center rounded-full bg-gradient-to-br from-primary to-secondary text-sm font-bold text-white shadow-md">
						{post.author.charAt(0).toUpperCase()}
					</div>
					<div>
						<p class="text-sm font-semibold text-on-surface">{post.author}</p>
						<p class="text-xs text-on-surface-variant dark:text-gray-400">Autor</p>
					</div>
				</div>
			)}

			<!-- Featured image hero -->
			{post.featured_image_url && (
				<div class="relative mt-10 overflow-hidden rounded-3xl shadow-xl">
					<img src={post.featured_image_url} alt={post.title} class="aspect-video w-full object-cover" loading="eager" />
				</div>
			)}
		</div>

		<!-- Content -->
		<div class="relative mx-auto mt-12 max-w-4xl px-8 pb-12">
			<div class="prose prose-lg prose-headings:font-headline prose-headings:font-extrabold prose-headings:tracking-tight prose-headings:text-on-surface prose-p:leading-relaxed prose-p:text-on-surface-variant prose-a:text-primary prose-a:no-underline hover:prose-a:underline prose-blockquote:border-l-primary prose-blockquote:bg-primary/5 prose-blockquote:py-1 prose-blockquote:not-italic prose-strong:text-on-surface prose-code:rounded-md prose-code:bg-surface-container-highest prose-code:px-1.5 prose-code:py-0.5 prose-code:text-sm prose-code:font-normal prose-pre:rounded-2xl prose-pre:bg-gray-900 prose-pre:shadow-xl prose-pre:dark:bg-gray-950 prose-img:rounded-2xl prose-img:shadow-lg max-w-none text-on-surface-variant dark:prose-invert" set:html={renderedContent} />
		</div>

		<!-- Image gallery (if has additional images beyond featured) -->
		{galleryImages.length > 1 && (
			<div class="relative mx-auto max-w-5xl px-8 pb-16">
				<div class="mb-8 flex items-center gap-4">
					<div class="h-px flex-1 bg-surface-variant/30" />
					<span class="inline-flex items-center gap-1.5 text-xs font-bold uppercase tracking-[0.16em] text-on-surface-variant dark:text-gray-400">
						<span class="material-symbols-outlined text-sm">photo_library</span>
						Galería del artículo
					</span>
					<div class="h-px flex-1 bg-surface-variant/30" />
				</div>

				<div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3">
					{galleryImages.map((img) => (
						<div class="group relative overflow-hidden rounded-2xl shadow-lg transition-all duration-300 hover:shadow-xl hover:-translate-y-0.5">
							<div class="aspect-[4/3] w-full overflow-hidden bg-surface-container-highest">
								<img
									src={img.url}
									alt={img.alt}
									class="h-full w-full object-cover transition-all duration-500 group-hover:scale-105"
									loading="lazy"
								/>
							</div>
							{img.isFeatured && (
								<span class="absolute top-2 right-2 rounded-full bg-primary/90 px-2.5 py-0.5 text-[10px] font-bold uppercase tracking-wider text-white backdrop-blur-sm">
									Destacada
								</span>
							)}
						</div>
					))}
				</div>
			</div>
		)}
	</article>

	<!-- Divider -->
	<div class="relative h-16 bg-surface-bright dark:bg-gray-950">
		<div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-primary/20 to-transparent" />
	</div>

	<!-- Related posts -->
	{related && related.length > 0 && (
		<section class="bg-surface-bright pb-16 dark:bg-gray-950">
			<div class="mx-auto max-w-7xl px-8">
				<RelatedPosts currentSlug={post.slug} posts={related} readingTime={true} />
			</div>
		</section>
	)}

	<!-- CTA -->
	<section class="py-20">
		<div class="mx-auto max-w-4xl px-8">
			<PostCta />
		</div>
	</section>
</MainLayout>
